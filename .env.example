# ── LLM providers ──────────────────────────────────────────────────────────────
# At least one key is required. Any number can coexist for round-robin rotation.
ANTHROPIC_API_KEY=sk-ant-
DEEPSEEK_API_KEY=sk-
OPENROUTER_API_KEY=sk-or-
# Google AI Studio key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# auto=round-robin | anthropic | deepseek | openrouter | gemini | ollama
LLM_PROVIDER=auto

ANTHROPIC_MODEL=claude-sonnet-4-20250514
DEEPSEEK_MODEL=deepseek-chat
# Any model slug from https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o-mini
GEMINI_MODEL=gemini-3.5-flash
# Used automatically when GEMINI_MODEL errors (e.g. "high demand" 429/503).
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite

# Local Ollama (no API key required).
# When running via Docker, use host.docker.internal instead of localhost:
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# When running without Docker:
# OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_THINK=False

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/jobs.db

# ── Search defaults ─────────────────────────────────────────────────────────────
DEFAULT_KEYWORD=Agent
DEFAULT_LOCATION=
DEFAULT_LANGUAGE=en
SEARCH_RADIUS_KM=30
KEYWORD_PRESETS={"devops": ["DevOps engineer", "SRE", "platform engineer", "infrastructure engineer"], "backend": ["backend engineer", "Go engineer", "Python engineer"]}

# ── Dedup ───────────────────────────────────────────────────────────────────────
SEMANTIC_SIMILARITY_THRESHOLD=0.92
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Scraper ─────────────────────────────────────────────────────────────────────
SCRAPER_DELAY_MIN=1.5
SCRAPER_DELAY_MAX=4.0
SCRAPER_MAX_PAGES=10
PLAYWRIGHT_HEADLESS=true

# ── LinkedIn (optional) ──────────────────────────────────────────────────────────
# Paste the `li_at` cookie value from your browser to enable authenticated search.
# How to get it: open linkedin.com → F12 → Application → Cookies → li_at → copy Value
# Without this, LinkedIn search is capped at ~40 results (guest mode).
LINKEDIN_COOKIE=
# Optional proxy for LinkedIn scraping. Switch this if your IP gets blocked.
# Formats: http://host:port  |  http://user:pass@host:port  |  socks5://host:port
LINKEDIN_PROXY=

# ── Email application ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
APPLY_FROM_EMAIL=your@email.com
APPLY_FROM_NAME=Your Name

# ── Scheduler ───────────────────────────────────────────────────────────────────
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 8 * * 1-5

# ── CV path ─────────────────────────────────────────────────────────────────────
CV_PDF_PATH=./data/cv.pdf
CV_TEXT_PATH=./data/cv.txt

# ── Docker / frontend ─────────────────────────────────────────────────────────
# Base URL the browser uses to reach the backend API. Inlined into the frontend
# bundle at build time. Defaults to http://localhost:8765 (local compose). For a
# remote deploy, set this to the public backend address, e.g.
# VITE_API_BASE_URL=https://jobs.example.com:8765
# VITE_API_BASE_URL=http://localhost:8765
# VITE_API_BASE_URL=http://tailscale-ip:8765
